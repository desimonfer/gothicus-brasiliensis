<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Oráculo · Bestiário Gothicus brasiliensis</title>
<style>
@font-face{font-family:'Brasilero';src:url('https://raw.githubusercontent.com/desimonfer/fontes/main/Brasilero2018Free.otf') format('opentype')}
@font-face{font-family:'Freeway Gothic';src:url('https://raw.githubusercontent.com/desimonfer/fontes/main/freewaygothic.ttf') format('truetype')}
*{box-sizing:border-box;margin:0;padding:0}
body{background:#0a0908;color:#f0ece4;font-family:'Freeway Gothic','Helvetica Neue',sans-serif;min-height:100vh;overflow-x:hidden}
.brasilero{font-family:'Brasilero',Georgia,serif}

/* HEADER */
.header{text-align:center;padding:48px 20px 24px}
.header .sub{font-size:9px;letter-spacing:0.4em;text-transform:uppercase;color:rgba(240,236,228,0.15);margin-bottom:10px}
.header h1{font-size:32px;font-weight:400;letter-spacing:0.04em;margin-bottom:6px}
.header h1 span{color:rgba(240,236,228,0.25)}
.header .desc{font-size:11px;color:rgba(240,236,228,0.2);font-style:italic}

/* MODE SELECTOR */
.modes{display:flex;justify-content:center;gap:2px;padding:0 20px 32px;flex-wrap:wrap}
.mode-btn{
  background:transparent;border:1px solid rgba(240,236,228,0.08);
  color:rgba(240,236,228,0.3);padding:10px 20px;font-size:10px;
  letter-spacing:0.15em;text-transform:uppercase;cursor:pointer;
  font-family:inherit;transition:all 0.2s;
}
.mode-btn:hover{border-color:rgba(240,236,228,0.2);color:#f0ece4}
.mode-btn.active{border-color:#e85d26;color:#e85d26;background:rgba(232,93,38,0.05)}

/* SHUFFLE AREA */
.shuffle-area{text-align:center;padding:0 20px 40px}
.shuffle-btn{
  background:transparent;border:1px solid rgba(240,236,228,0.12);
  color:rgba(240,236,228,0.5);padding:14px 40px;font-size:11px;
  letter-spacing:0.2em;text-transform:uppercase;cursor:pointer;
  font-family:inherit;transition:all 0.3s;
}
.shuffle-btn:hover{border-color:#e85d26;color:#e85d26}
.shuffle-hint{font-size:9px;color:rgba(240,236,228,0.1);letter-spacing:0.2em;margin-top:12px;text-transform:uppercase}

/* SPREAD CONTAINER */
.spread{display:none;padding:0 20px 60px;max-width:960px;margin:0 auto}
.spread.show{display:block}

/* CARD SLOT */
.slots{display:flex;flex-wrap:wrap;gap:16px;justify-content:center;margin-bottom:40px}
.slot{
  display:flex;flex-direction:column;align-items:center;gap:8px;
  width:140px;
}
.slot.large{width:180px}
.slot-label{font-size:8px;letter-spacing:0.2em;text-transform:uppercase;color:rgba(240,236,228,0.2);text-align:center;line-height:1.4}
.slot-sublabel{font-size:7px;color:rgba(240,236,228,0.1);text-align:center;font-style:italic;line-height:1.3}

/* CARD */
.card{
  width:100%;aspect-ratio:2/3;border-radius:6px;
  background:#0e0c0a;border:1px solid rgba(240,236,228,0.08);
  cursor:pointer;transition:all 0.3s;position:relative;overflow:hidden;
  perspective:600px;
}
.card:hover{border-color:rgba(240,236,228,0.15);transform:translateY(-2px)}
.card.revealed{border-color:rgba(240,236,228,0.12)}
.card.reversed .card-content{transform:rotate(180deg)}

.card-face{
  width:100%;height:100%;display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  padding:12px 8px;
}
.card-face.back{
  background-image:
    repeating-linear-gradient(45deg,transparent,transparent 12px,rgba(240,236,228,0.005) 12px,rgba(240,236,228,0.005) 13px),
    repeating-linear-gradient(-45deg,transparent,transparent 12px,rgba(240,236,228,0.005) 12px,rgba(240,236,228,0.005) 13px);
}
.card-face.back::before{content:'';position:absolute;inset:6px;border:1px solid rgba(240,236,228,0.03);border-radius:4px}
.card-back-logo{font-size:9px;letter-spacing:0.25em;text-transform:uppercase;color:rgba(240,236,228,0.06);writing-mode:vertical-rl}
.card-back-sigil{font-size:32px;opacity:0.04;position:absolute}

.card-content{width:100%;height:100%;display:flex;flex-direction:column;padding:10px 8px}
.card-accent-line{height:2px;width:100%;margin-bottom:8px;flex-shrink:0}
.card-sym{font-size:32px;text-align:center;margin-bottom:4px;filter:grayscale(30%)}
.card-cat{font-size:7px;letter-spacing:0.15em;text-transform:uppercase;text-align:center;margin-bottom:4px}
.card-name{font-size:14px;font-weight:400;text-align:center;line-height:1.2;margin-bottom:2px}
.card-sub{font-size:7px;font-style:italic;color:rgba(240,236,228,0.3);text-align:center;margin-bottom:6px;line-height:1.3}
.card-keyword{font-size:7px;letter-spacing:0.1em;text-align:center;color:rgba(240,236,228,0.25);margin-bottom:auto;text-transform:uppercase}
.card-reversed-tag{font-size:6px;letter-spacing:0.15em;text-transform:uppercase;text-align:center;color:rgba(232,93,38,0.5);margin-top:4px}

/* READING PANEL */
.reading{
  background:#0d0b09;border:1px solid rgba(240,236,228,0.05);
  padding:32px;margin-top:8px;display:none;
}
.reading.show{display:block}
.reading-title{font-size:9px;letter-spacing:0.3em;text-transform:uppercase;color:rgba(240,236,228,0.15);margin-bottom:24px}
.reading-cards{display:flex;flex-direction:column;gap:24px}
.reading-card-item{border-left:1px solid rgba(240,236,228,0.06);padding-left:20px}
.reading-card-item .pos{font-size:8px;letter-spacing:0.2em;text-transform:uppercase;color:rgba(240,236,228,0.2);margin-bottom:4px}
.reading-card-item .creature-name{font-size:18px;font-weight:400;color:#f0ece4;margin-bottom:2px}
.reading-card-item .creature-sub{font-size:10px;font-style:italic;color:rgba(240,236,228,0.3);margin-bottom:10px}
.reading-card-item .orientation{font-size:7px;letter-spacing:0.15em;text-transform:uppercase;margin-bottom:8px}
.orientation.up{color:#7ecba1}
.orientation.rev{color:#e85d26}
.reading-card-item .theme{font-size:12px;color:rgba(240,236,228,0.7);margin-bottom:6px;font-style:italic}
.reading-card-item .message{font-size:11px;color:rgba(240,236,228,0.5);line-height:1.7;margin-bottom:8px}
.reading-card-item .advice-label{font-size:7px;letter-spacing:0.15em;text-transform:uppercase;color:rgba(240,236,228,0.15);margin-bottom:4px}
.reading-card-item .advice{font-size:11px;color:rgba(240,236,228,0.4);line-height:1.6;font-style:italic}
.reading-divider{height:1px;background:rgba(240,236,228,0.04);margin:20px 0}

/* CELTIC CROSS LAYOUT */
.celtic-layout{position:relative;width:100%;max-width:600px;margin:0 auto;aspect-ratio:1.4}
.celtic-slot{position:absolute;width:14%;aspect-ratio:2/3}

/* NAV */
.nav{display:flex;justify-content:center;gap:20px;padding:32px 20px;font-size:10px;letter-spacing:0.15em;text-transform:uppercase}
.nav a{color:rgba(240,236,228,0.15);text-decoration:none;transition:color 0.15s}
.nav a:hover{color:#f0ece4}

/* THREE CARD SPREAD */
.three-slots{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}

@media(max-width:500px){
  .slot{width:110px}
  .slot.large{width:140px}
  .card-sym{font-size:24px}
  .card-name{font-size:12px}
}
</style>
</head>
<body>

<div class="header">
  <div class="sub">oráculo das criaturas</div>
  <h1 class="brasilero">Oráculo <span>Gothicus</span></h1>
  <p class="desc">escolha uma modalidade e consulte as criaturas</p>
</div>

<div class="modes">
  <button class="mode-btn active" onclick="setMode('day')">carta do dia</button>
  <button class="mode-btn" onclick="setMode('three')">tiragem de três</button>
  <button class="mode-btn" onclick="setMode('celtic')">cruz celta</button>
</div>

<div class="shuffle-area">
  <button class="shuffle-btn brasilero" onclick="draw()">consultar o bestiário</button>
  <div class="shuffle-hint" id="hint">toque para revelar cada carta</div>
</div>

<div class="spread" id="spread">
  <div class="slots" id="slots"></div>
  <div class="reading" id="reading">
    <div class="reading-title">leitura completa</div>
    <div class="reading-cards" id="readingCards"></div>
  </div>
</div>

<div class="nav">
  <a href="../bestiario/">bestiário</a>
  <a href="../cartas/">cartas</a>
  <a href="../">manifesto</a>
</div>

<script src="../bestiario/data.js"></script>
<script src="tarot.js"></script>
<script>
const catColors={Encantada:'#d4a017',Fantasma:'#7f8c8d',Protetor:'#27ae60',Protetora:'#27ae60',Predador:'#e74c3c','Morto-vivo':'#8b7355',Amaldiçoado:'#6c3483',Feiticeira:'#9b59b6',Traquinas:'#e67e22'};

let mode='day';
let drawn=[];
let revealed=[];

function setMode(m){
  mode=m;
  document.querySelectorAll('.mode-btn').forEach(b=>b.classList.remove('active'));
  event.target.classList.add('active');
  document.getElementById('spread').classList.remove('show');
  document.getElementById('reading').classList.remove('show');
  drawn=[];revealed=[];
  const hints={day:'toque na carta para revelar a criatura',three:'toque em cada carta para revelar',celtic:'toque em cada carta para revelar — da situação ao resultado'};
  document.getElementById('hint').textContent=hints[m];
}

function shuffle(arr){
  const a=[...arr];
  for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}
  return a;
}

function draw(){
  const pool=shuffle(creatures);
  const counts={day:1,three:3,celtic:10};
  const n=counts[mode];
  drawn=pool.slice(0,n).map(c=>({creature:c,reversed:Math.random()>0.5}));
  revealed=new Array(n).fill(false);
  renderSlots();
  document.getElementById('spread').classList.add('show');
  document.getElementById('reading').classList.remove('show');
}

function renderSlots(){
  const container=document.getElementById('slots');
  container.innerHTML='';

  if(mode==='day'){
    container.style.cssText='display:flex;justify-content:center;';
    const d=drawn[0];
    const el=makeSlot(d,0,'','',true);
    container.appendChild(el);
  } else if(mode==='three'){
    container.style.cssText='display:flex;gap:16px;justify-content:center;flex-wrap:wrap;';
    threeCardPositions.forEach((pos,i)=>{
      const el=makeSlot(drawn[i],i,pos.name,pos.description,false);
      container.appendChild(el);
    });
  } else {
    container.style.cssText='display:flex;gap:12px;justify-content:center;flex-wrap:wrap;';
    celticCrossPositions.forEach((pos,i)=>{
      const el=makeSlot(drawn[i],i,pos.name,pos.description,false);
      container.appendChild(el);
    });
  }
}

function makeSlot(data,idx,label,sublabel,large){
  const slot=document.createElement('div');
  slot.className='slot'+(large?' large':'');

  if(label){
    const lbl=document.createElement('div');
    lbl.className='slot-label';
    lbl.textContent=label;
    slot.appendChild(lbl);
    if(sublabel){
      const sub=document.createElement('div');
      sub.className='slot-sublabel';
      sub.textContent=sublabel;
      slot.appendChild(sub);
    }
  }

  const card=document.createElement('div');
  card.className='card';
  card.innerHTML=`<div class="card-face back"><div class="card-back-sigil">🌿</div><div class="card-back-logo">Bestiário</div></div>`;
  card.onclick=()=>revealCard(idx,card,data);
  slot.appendChild(card);
  return slot;
}

function revealCard(idx,card,data){
  if(revealed[idx]) return;
  revealed[idx]=true;

  const c=data.creature;
  const rev=data.reversed;
  const acc=c.colors.accent;
  const cc=catColors[c.category]||'#888';
  const t=tarot[c.name];

  card.classList.add('revealed');
  if(rev) card.classList.add('reversed');

  card.innerHTML=`
    <div class="card-content">
      <div class="card-accent-line" style="background:linear-gradient(90deg,transparent,${acc},transparent)"></div>
      <div class="card-sym">${c.symbol}</div>
      <div class="card-cat" style="color:${cc}">${c.category}</div>
      <div class="card-name brasilero">${c.name}</div>
      <div class="card-sub">${c.subtitle}</div>
      <div class="card-keyword">${t?t.keywords[0]:''}</div>
      ${rev?`<div class="card-reversed-tag">invertida</div>`:''}
    </div>
  `;

  checkAllRevealed();
}

function checkAllRevealed(){
  if(revealed.every(r=>r)) showReading();
}

function showReading(){
  const container=document.getElementById('readingCards');
  container.innerHTML='';

  drawn.forEach((data,i)=>{
    const c=data.creature;
    const rev=data.reversed;
    const t=tarot[c.name];
    if(!t) return;

    const meaning=rev?t.reversed:t.upright;
    let posName='';
    if(mode==='three') posName=threeCardPositions[i].name;
    else if(mode==='celtic') posName=celticCrossPositions[i].name;

    const item=document.createElement('div');
    item.className='reading-card-item';
    item.innerHTML=`
      ${posName?`<div class="pos">${posName}</div>`:''}
      <div class="creature-name brasilero">${c.name} ${c.symbol}</div>
      <div class="creature-sub">${c.subtitle}</div>
      <div class="orientation ${rev?'rev':'up'}">${rev?'▽ invertida':'△ direta'}</div>
      <div class="theme">${meaning.theme}</div>
      <div class="message">${meaning.message}</div>
      <div class="advice-label">conselho</div>
      <div class="advice">${meaning.advice}</div>
    `;

    if(i<drawn.length-1){
      const div=document.createElement('div');
      div.className='reading-divider';
      item.appendChild(div);
    }

    container.appendChild(item);
  });

  document.getElementById('reading').classList.add('show');
  document.getElementById('reading').scrollIntoView({behavior:'smooth',block:'start'});
}
</script>
</body>
</html>

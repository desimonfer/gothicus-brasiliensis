        // Carregar dados
        $emails = [];
        if (file_exists('emails.json')) {
            $emails = json_decode(file_get_contents('emails.json'), true) ?? [];
        }

        // Deletar email
        if (isset($_GET['delete'])) {
            $id = intval($_GET['delete']);
            array_splice($emails, $id, 1);
            file_put_contents('emails.json', json_encode($emails, JSON_PRETTY_PRINT));
            header('Location: admin.php');
            exit;
        }

        $total = count($emails);
        $today = date('Y-m-d');
        $today_count = count(array_filter($emails, fn($e) => str_starts_with($e['date'], $today)));
        ?>

